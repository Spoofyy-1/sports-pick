{
  "$schema": "https://schema.railpack.com",
  "provider": "python",
  "buildAptPackages": [],
  "packages": {
    "python": "3.11"
  },
  "steps": {
    "install": {
      "commands": [
        "pip install --upgrade pip",
        "pip install -r backend/requirements.txt"
      ]
    }
  },
  "deploy": {
    "startCommand": "cd backend && uvicorn api.main:app --host 0.0.0.0 --port $PORT"
  }
}
